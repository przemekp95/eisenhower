    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
