{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:e2e": "node scripts/runPlaywright.js test",
    "test:e2e:headed": "node scripts/runPlaywright.js test --headed",
    "test:e2e:install": "node scripts/runPlaywright.js install chromium",
    "test:e2e:ai-smoke": "node scripts/runPlaywright.js test --config=playwright.ai-smoke.config.ts",
    "test:e2e:ai-smoke:headed": "node scripts/runPlaywright.js test --config=playwright.ai-smoke.config.ts --headed"
  },
  "dependencies": {
    "@eisenhower/api-client": "file:../packages/api-client",
    "@hello-pangea/dnd": "^18.0.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.18",
    "pixi.js": "^8.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.3",
    "vite": "^7.3.1"
  }
